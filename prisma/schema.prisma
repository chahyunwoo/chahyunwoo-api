generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["analytics", "auth", "blog", "portfolio"]
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model AdminSetting {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  value      String?  @db.Text
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_settings")
  @@schema("auth")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique @map("token_hash") @db.VarChar(128)
  username  String   @db.VarChar(200)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([username])
  @@index([expiresAt])
  @@map("refresh_tokens")
  @@schema("auth")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model Category {
  id        Int    @id @default(autoincrement())
  name      String @unique @db.VarChar(200)
  icon      String @default("LayoutGrid") @db.VarChar(100)
  sortOrder Int    @default(0) @map("sort_order")

  @@index([sortOrder])
  @@map("categories")
  @@schema("blog")
}

model Post {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(500)
  slug         String    @unique @db.VarChar(500)
  description  String?   @db.Text
  content      String    @db.Text
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(1000)
  category     String?   @db.VarChar(200)
  published    Boolean   @default(false)
  publishedAt  DateTime? @map("published_at") @db.Timestamptz(6)
  readingTime  Int       @default(0) @map("reading_time")
  viewCount    Int       @default(0) @map("view_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  postTags     PostTag[]

  @@index([published, publishedAt(sort: Desc)])
  @@index([category])
  @@map("posts")
  @@schema("blog")
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(200)
  slug     String    @unique @db.VarChar(200)
  postTags PostTag[]

  @@map("tags")
  @@schema("blog")
}

model PostTag {
  postId Int  @map("post_id")
  tagId  Int  @map("tag_id")
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
  @@schema("blog")
}

// ─── Portfolio ───────────────────────────────────────────────────────────────

model Locale {
  id    Int    @id @default(autoincrement())
  code  String @unique @db.VarChar(5)
  label String @db.VarChar(50)

  @@map("locales")
  @@schema("portfolio")
}

model Profile {
  id           Int                  @id @default(autoincrement())
  name         String               @db.VarChar(100)
  location     String               @db.VarChar(200)
  imageUrl     String?              @map("image_url") @db.VarChar(1000)
  iconUrl      String?              @map("icon_url") @db.VarChar(1000)
  socialLinks  Json?                @map("social_links")
  translations ProfileTranslation[]

  @@map("profiles")
  @@schema("portfolio")
}

model ProfileTranslation {
  id           Int      @id @default(autoincrement())
  profileId    Int      @map("profile_id")
  locale       String   @db.VarChar(5)
  jobTitle     String   @map("job_title") @db.VarChar(200)
  introduction String[] @db.Text
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, locale])
  @@map("profile_translations")
  @@schema("portfolio")
}

model Experience {
  id           Int                     @id @default(autoincrement())
  sortOrder    Int                     @default(0) @map("sort_order")
  startDate    String                  @map("start_date") @db.VarChar(50)
  endDate      String?                 @map("end_date") @db.VarChar(50)
  isCurrent    Boolean                 @default(false) @map("is_current")
  translations ExperienceTranslation[]

  @@index([sortOrder])
  @@map("experiences")
  @@schema("portfolio")
}

model ExperienceTranslation {
  id               Int        @id @default(autoincrement())
  experienceId     Int        @map("experience_id")
  locale           String     @db.VarChar(5)
  title            String     @db.VarChar(300)
  role             String     @db.VarChar(300)
  responsibilities String[]   @db.Text
  experience       Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([experienceId, locale])
  @@map("experience_translations")
  @@schema("portfolio")
}

model Project {
  id           Int                  @id @default(autoincrement())
  sortOrder    Int                  @default(0) @map("sort_order")
  demoUrl      String?              @map("demo_url") @db.VarChar(1000)
  repoUrl      String?              @map("repo_url") @db.VarChar(1000)
  techStack    Json                 @default("[]") @map("tech_stack")
  featured     Boolean              @default(false)
  translations ProjectTranslation[]

  @@index([sortOrder])
  @@index([featured])
  @@map("projects")
  @@schema("portfolio")
}

model ProjectTranslation {
  id          Int     @id @default(autoincrement())
  projectId   Int     @map("project_id")
  locale      String  @db.VarChar(5)
  title       String  @db.VarChar(500)
  description String? @db.Text
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@map("project_translations")
  @@schema("portfolio")
}

model Work {
  id           Int               @id @default(autoincrement())
  type         String            @db.VarChar(20)
  sortOrder    Int               @default(0) @map("sort_order")
  startDate    String?           @map("start_date") @db.VarChar(50)
  endDate      String?           @map("end_date") @db.VarChar(50)
  isCurrent    Boolean           @default(false) @map("is_current")
  techStack    Json              @default("[]") @map("tech_stack")
  demoUrl      String?           @map("demo_url") @db.VarChar(1000)
  repoUrl      String?           @map("repo_url") @db.VarChar(1000)
  featured     Boolean           @default(false)
  translations WorkTranslation[]

  @@index([type, sortOrder])
  @@index([featured])
  @@map("works")
  @@schema("portfolio")
}

model WorkTranslation {
  id         Int      @id @default(autoincrement())
  workId     Int      @map("work_id")
  locale     String   @db.VarChar(5)
  title      String   @db.VarChar(500)
  role       String?  @db.VarChar(300)
  summary    String   @db.Text
  content    String   @db.Text
  highlights String[] @db.Text
  work       Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, locale])
  @@map("work_translations")
  @@schema("portfolio")
}

model Skill {
  id          Int     @id @default(autoincrement())
  category    String  @db.VarChar(100)
  name        String  @db.VarChar(200)
  sortOrder   Int     @default(0) @map("sort_order")
  proficiency Int     @default(0)
  description String? @db.Text

  @@index([category])
  @@index([sortOrder])
  @@map("skills")
  @@schema("portfolio")
}

model Education {
  id           Int                    @id @default(autoincrement())
  period       String                 @db.VarChar(100)
  sortOrder    Int                    @default(0) @map("sort_order")
  translations EducationTranslation[]

  @@index([sortOrder])
  @@map("education")
  @@schema("portfolio")
}

model EducationTranslation {
  id          Int       @id @default(autoincrement())
  educationId Int       @map("education_id")
  locale      String    @db.VarChar(5)
  institution String    @db.VarChar(300)
  degree      String    @db.VarChar(300)
  education   Education @relation(fields: [educationId], references: [id], onDelete: Cascade)

  @@unique([educationId, locale])
  @@map("education_translations")
  @@schema("portfolio")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(300)
  subject   String?  @db.VarChar(200)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([read])
  @@map("contact_messages")
  @@schema("portfolio")
}

// ─── Analytics ──────────────────────────────────────────────────────────────

model PageView {
  id        Int      @id @default(autoincrement())
  path      String   @db.VarChar(500)
  appName   String   @map("app_name") @db.VarChar(50)
  referrer  String?  @db.VarChar(1000)
  userAgent String?  @map("user_agent") @db.VarChar(1000)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([appName, createdAt(sort: Desc)])
  @@index([path])
  @@index([createdAt(sort: Desc)])
  @@map("page_views")
  @@schema("analytics")
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  action    String   @db.VarChar(50)
  entity    String   @db.VarChar(50)
  entityId  String?  @map("entity_id") @db.VarChar(100)
  detail    String?  @db.Text
  username  String   @db.VarChar(200)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([entity])
  @@map("admin_logs")
  @@schema("analytics")
}
