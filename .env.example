NODE_ENV=development
PORT=8000

# Database - full connection string
DATABASE_URL=postgresql://user:password@localhost:5432/hyunwoo?schema=public

# JWT - generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Admin credentials
ADMIN_USERNAME=admin
# Generate hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('your_password',12))"
ADMIN_PASSWORD_HASH=$2a$12$...

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=hyunwoo-assets
R2_PUBLIC_URL=https://assets.chahyunwoo.dev

# API Key - generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your_api_key_here

# Revalidation
BLOG_REVALIDATE_URL=https://chahyunwoo.dev
PORTFOLIO_REVALIDATE_URL=https://portfolio.chahyunwoo.dev
REVALIDATE_SECRET=your_revalidate_secret_here

# CORS (comma-separated)
ALLOWED_ORIGINS=https://chahyunwoo.dev,https://www.chahyunwoo.dev
